# Copy to .env and adjust. Used by docker-compose, Cloud Run env vars, and local dev (npm run dev).

SITE_NAME=CTY TRANSPORTATION
SITE_TAGLINE=Business-class NYC airport & luxury chauffeured service
SITE_DESCRIPTION=CTY Transportation serves Mississauga and the greater NYC metro: business-class airport transfers, VVIP limos, black SUVs, hourly chauffeurs, family vans, and luxury vans for large groups.

OWNER_NAME=Manvir Kaur
OWNER_EMAIL=you@example.com

# Direct form POST (no custom backend). Create a form at https://formspree.io and paste your endpoint:
# CONTACT_FORM_ACTION=https://formspree.io/f/xxxxxxxx
CONTACT_FORM_ACTION=https://formspree.io/f/REPLACE_ME

PRIMARY_PHONE=(929) 390-5862

# Optional full URL e.g. https://wa.me/15551234567
WHATSAPP_URL=

META_KEYWORDS=CTY Transportation, Mississauga limo, NYC airport car service, black SUV, luxury van, VVIP limo, hourly chauffeur, Manvir Kaur
META_OG_IMAGE=

# Local only: host port mapped to the container (container always listens on 8080)
# HOST_PORT=80
